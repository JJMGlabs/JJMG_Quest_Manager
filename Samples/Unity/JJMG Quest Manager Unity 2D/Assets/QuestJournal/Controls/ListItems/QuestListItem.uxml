<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xmlns="UnityEngine.UIElements" ue="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:Box class="questListItemContainer">
        <ui:Label name="Chevron" text="" class="chevronLabel" />
        <ui:Label tabindex="-1" name="QuestName" text="Label" parse-escape-sequences="true" display-tooltip-when-elided="true" binding-path="name" />
    </ui:Box>
</ui:UXML>
